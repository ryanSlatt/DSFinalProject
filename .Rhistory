# Code gets exchange rates from Dbnomics and plots them in an "index" graph
# rates are: Czechia (CZK), Hungary (HUF), Poland (PLN), Romania (RON)
# rates are domestic/USD so increases mean weaker local currency, strong USD
# Modified: 9/25/2024 by Ryan Slattery
# Set the working directory
#setwd("YOUR FILEPATH HERE)
# Load the required libraries
library(ggplot2)
library(tidyverse)
library(eurostat)
#Getting the data
prices = get_eurostat("ert_bil_eur_d", filters = list(
freq = "D",       # Daily frequency
statinfo = "AVG",     # Average rates
CURRENCY = c("HUF", "RON", "CZK", "PLN","USD")
))
#Getting rid of extra columns
prices = prices %>% select("currency","time","values")
#This will filter it to the last week of data
lastFriday      = as.Date(Sys.Date() - wday(Sys.Date())) # the dates are setting a time window of the last full week
twoFridaysAgo   = lastFriday - days(8)
prices = prices %>% mutate(time = as.Date(time))
prices = prices %>%
filter(time >= as.Date(twoFridaysAgo) & time <= as.Date(lastFriday))
#Flipping the USD/EUR rate to obtain EUR/USD. Used in calculations
prices = prices %>%  mutate(values = ifelse(currency == "USD", 1 / values, values))
#Multiplying by the EUR/USD rate
prices = prices %>% group_by(time) %>% mutate(USDrate = values[currency == "USD"])
prices = prices %>% mutate(values = ifelse(currency != "USD", values * USDrate, values))
#Getting rid of the extra column we made
prices = prices %>% select("currency","time","values")
#Renaming certain variables to match up with our old plot code.
#May try to avoid this later
prices = prices %>% rename(Date = time)
prices = prices %>% rename(adjusted = values)
prices = prices %>% rename(symbol = currency)
#For reports that don't use the EUR/USD (not Atlantic) - drop the EUR/USD entries
prices = prices %>% filter(symbol != "USD")
# Calculate the percentage change from the starting price for each currency
prices <- prices %>%
group_by(symbol) %>%
mutate(pct_change = (adjusted - adjusted[1]) / adjusted[1] * 100)
# Calculate the maximum absolute percentage change among currencies
max_pct_change <- max(abs(prices$pct_change))
# Adjust y-axis limits based on the most volatile currency
y_limits <- c(-max_pct_change, max_pct_change)
# Create and save a plot with refined aesthetics
plot <- ggplot(prices, aes(x = Date, y = pct_change, color = symbol)) +
geom_line(data = filter(prices, !is.na(pct_change)))
#geom_line(data = filter(prices, !is.na(pct_change))) +
labs(
#title = "Exchange Rate Percentage Change vs. USD over Past 7 Days",
x = "Date",
y = "Percentage Change (%)") +
scale_y_continuous(limits = y_limits) +
theme_bw() +
geom_hline(yintercept = 0, linetype = "dashed") +
theme(plot.background = element_rect(fill = "white"),
legend.title = element_blank())
# Displays the plot you just made.
plot
# Automatically sets the file name
lastMonday   = lastFriday - days(5)
formatted_date <- gsub("^0", "", format(lastMonday, "%m %d %y"))
file_name <- paste("Index Plot CEE ", formatted_date, ".png", sep = "")
# Use ggsave to save the ggplot as a .png file
ggsave(file_name, plot, width = 10, height = 6, dpi = 300)  # Adjust width, height, and dpi as needed
View(prices)
View(prices)
library(tidyverse)
library(tidyquant)
library(fixest)
library(readr)
### Setup ###
#Possible cutoff dates
chipsActPassed = as.Date("2022-07-28")
#Setting the cutoff date and the range of days to get
cutoffDate = chipsActPassed
range = 30
#Tickers of stocks
#NOTE - continue to include solar, some of those oddball small cap stocks?
#NOTE - removed "ALAB", a company that seems to have started in 2024
tickers = c("AAOI",	"ADI",	"AIP",	"ALGM",	"ALMU",	"AMBA",	"AMBQ",	"AMD",	"AOSL",	"AQ",	"ARM",	"ASX",	"AVGO",	"AXTI",	"CAVM",	"CEVA",	"CRDO",	"CRUS",	"CY",	"DIOD",	"DSPG",	"EMKR",	"ENPH",	"FSLR",	"GCTS",	"GFS",	"GSIT",	"HIMX",	"ICG",	"IDTI",	"IMI",	"IMOS",	"INDI",	"INTC",	"IOTS",	"IPHI",	"IPWR",	"KOPN",	"LAES",	"LASR",	"LEDS",	"LSCC",	"MCHP",	"MLNX",	"MOBX",	"MOSY",	"MPWR",	"MRAM",	"MRVL",	"MSCC",	"MTSI",	"MU",	"MX",	"MXIM",	"MXL",	"NA",	"NLST",	"NPTN",	"NVDA",	"NVEC",	"NVTS",	"NXPI",	"ON",	"PI",	"POET",	"POWI",	"PRSO",	"PXLW",	"QCOM",	"QRVO",	"QTNA",	"QUIK",	"RBCN",	"RESN",	"RMBS",	"SIGM",	"SIMO",	"SITM",	"SKYT",	"SLAB",	"SMTC",	"SPWR",	"SQNS",	"STM",	"SWKS",	"SYNA",	"TSEM",	"TSM",	"TXN",	"UMC",	"VLN",	"VSH",	"WKEY",	"WOLF",	"XLNX",	"XPER")
### Data Retrieval ###
#Getting the data from Yahoo finance
semiData = tq_get(tickers, get = "stock.prices", from = cutoffDate-range, to = cutoffDate+range)
#Getting the DOW/NASDAQ - NASDAQ appears to have better parallel trends
#NOTE - may be easier to just add this to the end of the list of tickers, but for now I have it as its own process
dowJones = tq_get("DOW", get = "stock.prices", from = cutoffDate-range, to = cutoffDate+range)
#nasdaq = tq_get("^IXIC", get = "stock.prices", from = cutoffDate-range, to = cutoffDate+range)
nasdaq = tq_get("NDX", get = "stock.prices", from = cutoffDate-range, to = cutoffDate+range)
#Future date:
#Yahoo finance appears to have some other data, like quarterly market cap
#https://finance.yahoo.com/quote/AMD/key-statistics/
#It's also a little paywalled
#Could do it manually, could maybe get a little web scrapey
### Data Cleaning / Prep for DiD ###
semiData = semiData %>% select(symbol, date, adjusted)
dowJones = dowJones %>% select(symbol, date, adjusted)
nasdaq = nasdaq %>% select(symbol, date, adjusted)
#Calculating a percent change - we aren't interested in stock price in dollars, but relative performance
semiData = semiData %>% mutate(pct_change = (adjusted - lag(adjusted))/lag(adjusted)*100)
dowJones = dowJones %>% mutate(pct_change = (adjusted - lag(adjusted))/lag(adjusted)*100)
nasdaq = nasdaq %>% mutate(pct_change = (adjusted - lag(adjusted))/lag(adjusted)*100)
###Constructing variables for DiD
#Treated Group
semiData = semiData %>% mutate(treatedGroup = 1)
dowJones = dowJones %>% mutate(treatedGroup = 0)
nasdaq = nasdaq %>% mutate(treatedGroup = 0)
#AfterCutoff
semiData = semiData %>% mutate(afterCutoff = case_when(date<cutoffDate ~ 0,
date >= cutoffDate ~ 1))
dowJones = dowJones %>% mutate(afterCutoff = case_when(date<cutoffDate ~ 0,
date >= cutoffDate ~ 1))
nasdaq = nasdaq %>% mutate(afterCutoff = case_when(date<cutoffDate ~ 0,
date >= cutoffDate ~ 1))
#############################################
### SINGLE TREATMENT VARIABLE - Going instead for Treated Group, After, TreatedGroup x After to better see group and time effects
# #Adding the "treatment" variable
# # Should be 1 for semiconductor stocks after the passage of CHIPS Act, 0 for all else
# semiData = semiData %>% mutate(treated = case_when(date<cutoffDate ~ 0,
#                                            date >= cutoffDate ~ 1))
# dowJones = dowJones %>% mutate(treated = 0)
# nasdaq = nasdaq %>% mutate(treated = 0)
##############################################
#Combining into one dataset for DiD
#fullData = rbind(semiData,dowJones)
fullData = rbind(semiData,nasdaq)
### Basic DiD Model ###
#Need to scale before doing the regression
#model = feols(fullData, adjusted ~ treatedGroup + afterCutoff + treatedGroup:afterCutoff)
# Using percent change as the outcome we get insignificant results. Perhaps too noisy
#model = feols(fullData, pct_change ~ treatedGroup + afterCutoff + treatedGroup:afterCutoff)
#model
#Regression with scaled prices - should we scale by individual company or group? Either way pretty good results
fullData = fullData %>% group_by(symbol) %>% mutate(scaled_price = scale(adjusted))
model = feols(fullData, scaled_price ~ treatedGroup + afterCutoff + treatedGroup:afterCutoff)
model
# fullData = fullData %>% group_by(treatedGroup) %>% mutate(scaled_price = scale(adjusted))
# model = feols(fullData, scaled_price ~ treatedGroup + afterCutoff + treatedGroup:afterCutoff)
# model
#This is the naive model with no fixed effects - shouldn't do it this way
#feols(fullData, adjusted ~ treatedGroup:afterCutoff)
### Plot for Checking Parallel Trends Assumption ###
